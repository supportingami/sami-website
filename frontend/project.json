{
  "name": "frontend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "frontend",
  "projectType": "application",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["TODO - create local yarn.lock", "yarn install"],
        "parallel": false,
        "outputPath": "frontend/.yarn.lock",
        "cwd": "frontend"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn next build",
        "parallel": false,
        "outputPath": "frontend/.next",
        "cwd": "frontend"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn next start",
        "parallel": false,
        "cwd": "frontend"
      }
    },
    "serve": {
      "options": {
        "command": "next dev",
        "parallel": false,
        "outputPath": "frontend/.next",
        "cwd": "frontend"
      }
    },

    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "graphql-codegen --require dotenv/config --config codegen.yml dotenv_config_path=./.env.local",
        "parallel": false,
        "cwd": "frontend"
      }
    },
    "analyze": {
      "executor": "nx:run-commands",
      "options": {
        "command": "set \"ANALYZE=true\" && next build frontend",
        "parallel": false
      },
      "configurations": {
        "unix": { "command": "ANALYZE=true next build frontend" }
      }
    },
    "turbo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev frontend --turbo",
        "parallel": false
      }
    },
    "export": {
      "executor": "@nrwl/next:export",
      "options": {
        "buildTarget": "frontend:build:production"
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "frontend/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["frontend/**/*.{ts,tsx,js,jsx}"]
      }
    }
  },
  "tags": []
}
