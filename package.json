{
  "name": "sami-website",
  "license": "see license.md",
  "workspaces": [
    "backend",
    "ci",
    "frontend",
    "scripts"
  ],
  "scripts": {
    "build": "nx run frontend:build",
    "deploy": "npx vercel",
    "export:frontend": "yarn workspace frontend export",
    "format": "yarn format:code && yarn format:style",
    "format:code": "eslint . --ext .js,.jsx,.ts,.tsx --color --fix",
    "format:style": "prettier --write '**/*.{md,json,js,tsx,ts}'",
    "generate": "yarn nx run frontend:generate && yarn pretty-quick",
    "lint": "yarn lint:code && yarn lint:style",
    "lint:code": "eslint . --ext .js,.jsx,.ts,.tsx --color",
    "lint:spell:TODO": "npx cspell \"**/*.md\" --config ./.cspell.json",
    "lint:style": "prettier --check '**/*.{md,json,js,tsx,ts}'",
    "release": "release-it",
    "scripts": "yarn workspace scripts start",
    "start": "yarn scripts dev start"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.14.5",
    "@graphql-codegen/cli": "^2.13.5",
    "@graphql-codegen/schema-ast": "^2.5.1",
    "@graphql-codegen/typed-document-node": "^2.3.3",
    "@graphql-codegen/typescript": "^2.7.3",
    "@graphql-codegen/typescript-operations": "^2.5.3",
    "@next/bundle-analyzer": "^12.3.1",
    "@nrwl/cypress": "15.6.3",
    "@nrwl/jest": "15.6.3",
    "@nrwl/js": "15.6.3",
    "@nrwl/next": "^15.6.3",
    "@nrwl/nx-cloud": "latest",
    "@nrwl/react": "15.6.3",
    "@release-it/conventional-changelog": "^5.0.0",
    "@tailwindcss/typography": "^0.5.4",
    "@testing-library/react": "13.4.0",
    "@types/jest": "28.1.1",
    "@types/node": "18.11.9",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "@typescript-eslint/eslint-plugin": "^5.42.1",
    "@typescript-eslint/parser": "^5.42.1",
    "autoprefixer": "^10.4.13",
    "babel-jest": "28.1.1",
    "cypress": "^12.2.0",
    "daisyui": "^2.50.0",
    "dotenv": "^16.0.1",
    "eslint": "^8.27.0",
    "eslint-config-next": "13.1.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-cypress": "^2.10.3",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "6.6.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "7.31.11",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-sort-class-members": "^1.15.2",
    "eslint-plugin-unicorn": "^44.0.2",
    "husky": "^8.0.1",
    "jest": "28.1.1",
    "jest-environment-jsdom": "28.1.1",
    "lint-staged": "^12.4.1",
    "nx": "15.6.3",
    "postcss": "^8.4.16",
    "prettier": "^2.7.1",
    "pretty-quick": "^3.1.3",
    "react-test-renderer": "18.2.0",
    "release-it": "^15.0.0",
    "sass": "1.55.0",
    "tailwindcss": "^3.1.8",
    "ts-jest": "28.0.5",
    "ts-node": "10.9.1",
    "typescript": "4.8.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,json,css,md,tsx,ts}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@3.2.4",
  "engines": {
    "node": ">=14.x <=16.x"
  }
}
